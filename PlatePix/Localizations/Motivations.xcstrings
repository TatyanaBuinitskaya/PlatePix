    "Motivation32" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you had started losing weight six months ago, you would already have a fit and toned body today. Don’t waste time"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gdybyś zaczął chudnąć sześć miesięcy temu, dziś miałbyś już wysportowaną i wyrzeźbioną sylwetkę. Nie marnuj czasu"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если бы ты начала худеть полгода назад, сегодня у тебя уже было бы красивое и подтянутое тело. Не теряй время"
