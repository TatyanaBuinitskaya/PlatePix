    "Motivation30" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "There will always be someone slimmer or more successful than you, so compare yourself not to them, but to who you were in the past"
