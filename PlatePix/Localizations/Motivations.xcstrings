{
  "sourceLanguage" : "en",
  "strings" : {
    "Motivation0" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your dream will never become a reality unless you start working toward it"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Twoje marzenie nigdy nie stanie się rzeczywistością, jeśli nie zaczniesz nad nim pracować"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Твоя мечта никогда не сбудется, если ты не начнешь двигаться к ней"
          }
        }
      }
    },
    "Motivation1" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Don't wait for the perfect moment - it will never come. Just start taking action"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nie czekaj na idealny moment - on nigdy nie nadejdzie. Po prostu zacznij działać"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Не жди идеального момента, он никогда не наступит. Просто начни действовать"
          }
        }
      }
    },
    "Motivation2" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You can achieve even the biggest goal by simply taking small steps every day"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Możesz osiągnąć nawet największy cel, po prostu robiąc małe kroki każdego dnia"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ты сможешь достичь даже самой амбициозной цели, если будешь делать маленькие шаги каждый день"
          }
        }
      }
    },
    "Motivation3" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Taking photos of your meals is the best way to track and control your eating habits"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Robienie zdjęć posiłków to najlepszy sposób na śledzenie i kontrolowanie swoich nawyków żywieniowych"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фотографирование своих приемов пищи — лучший способ отслеживать и контролировать пищевые привычки"
          }
        }
      }
    },
    "Motivation4" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eat healthy, train hard, and you’ll always be ahead of those who do nothing"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jedz zdrowo, trenuj ciężko, a zawsze będziesz przed tymi, którzy nic nie robią"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Следуй правильному питанию, тренируйся, и ты всегда будешь впереди тех, кто ничего не делает"
          }
        }
      }
    },
    "Motivation5" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Setbacks are part of the process. Don’t blame yourself—just keep moving toward your goal"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niepowodzenia są częścią procesu. Nie obwiniaj się - po prostu dalej dąż do swojego celu"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Срывы — часть процесса. Не вини себя, просто продолжай двигаться к цели"
          }
        }
      }
    },
    "Motivation6" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The first changes will be noticeable in two weeks, and visible results will appear in one or two months. Don't give up too soon"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pierwsze zmiany będą zauważalne po dwóch tygodniach, a widoczne efekty pojawią się po jednym lub dwóch miesiącach. Nie poddawaj się zbyt szybko"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Первые изменения будут заметны через две недели, а видимые результаты спустя один или два месяца, не сдавайся раньше времени"
          }
        }
      }
    },
    "Motivation7" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "It's hard to change your usual lifestyle, but it's even harder to spend your whole life wanting to change and never actually doing it"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trudno jest zmienić swój dotychczasowy styl życia, ale jeszcze trudniej jest spędzić całe życie, chcąc się zmienić, i nigdy tego nie zrobić"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Изменить свой привычный образ жизни трудно, но еще труднее всю жизнь хотеть изменений и так их и не достичь"
          }
        }
      }
    },
    "Motivation8" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eat more fiber-rich foods, and keep vegetables, fruits, and greens always on hand"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jedz więcej produktów bogatych w błonnik i zawsze miej pod ręką warzywa, owoce i zieleninę"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ешь больше продуктов богатых клетчаткой, пусть овощи, фрукты и зелень всегда будут под рукой"
          }
        }
      }
    },
    "Motivation9" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Do at least one thing today that brings you closer to your dream, and the day will be well spent"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zrób dziś przynajmniej jedną rzecz, która przybliży Cię do Twojego marzenia, a ten dzień będzie dobrze wykorzystany"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сделай хотя бы одно дело сегодня, которое приблизит тебя к твоей мечте, и день не будет прожит зря"
          }
        }
      }
    },
    "Motivation10" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Love your body now, not when you lose weight, because this is your dream body—it's just a work in progress"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pokochaj swoje ciało już dziś, a nie dopiero po osiągnięciu celu. To już jest Twoje wymarzone ciało - po prostu wciąż nad nim pracujesz"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Люби свое тело сейчас, а не когда похудеешь, ведь это и есть твое тело мечты, просто оно еще в процессе"
          }
        }
      }
    },
    "Motivation11" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Look at the people who have managed to lose weight. You’re just like them—if they could do it, so can you"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spójrz na osoby, którym udało się schudnąć. Jeśli im się udało, Tobie również się uda"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Посмотри на тех, кому удалось похудеть. Ты такой же человек, если смогли они — сможешь и ты"
          }
        }
      }
    },
    "Motivation12" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inner confidence and discipline will surely lead you to your goal"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pewność siebie i dyscyplina pomogą Ci osiągnąć każdy cel"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Внутренняя уверенность и дисциплина обязательно приведут тебя к твоей цели"
          }
        }
      }
    },
    "Motivation13" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The extra pounds didn’t come on overnight, so don’t expect them to disappear instantly. Give yourself time and patience"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dodatkowe kilogramy nie pojawiły się z dnia na dzień, więc nie oczekuj, że znikną od razu. Daj sobie czas i uzbrój się w cierpliwość"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Лишние килограммы не появились за одну ночь, поэтому не ожидай, что они исчезнут мгновенно. Дай себе время и терпение"
          }
        }
      }
    },
    "Motivation14" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Do your best now, and your future self will definitely thank you"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zrób dziś wszystko, co w Twojej mocy, a Twoje przyszłe ja będzie Ci za to wdzięczne"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Делай всё, что в твоих силах сейчас, и в будущем ты обязательно скажешь себе спасибо"
          }
        }
      }
    },
    "Motivation15" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The availability and convenience of foods define the foundation of your diet. Make sure healthy, low-calorie foods are always in your kitchen"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To, jakie produkty masz pod ręką, w dużej mierze wpływa na Twoje nawyki żywieniowe. Zadbaj o to, aby w Twojej kuchni zawsze były zdrowe i niskokaloryczne produkty"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Доступность и удобство продуктов определяют основу питания. Пусть полезные и низкокалорийные продукты всегда будут на твоей кухне"
          }
        }
      }
    },
    "Motivation16" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Motivation is what gets you moving, what sparks change, and gives you that initial push. After that, it's daily actions and discipline that make the difference"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Motywacja pomaga Ci ruszyć z miejsca i zrobić pierwszy krok. Jednak to codzienne nawyki i dyscyplina decydują o osiągnięciu celu"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Мотивация — это то, что заставляет сдвигаться с места, начать меняться, даёт толчок. А дальше нужны ежедневные действия и дисциплина"
          }
        }
      }
    },
    "Motivation17" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The pleasure of eating a pastry lasts 5 minutes, but you can enjoy your stunning reflection in the mirror every day"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przyjemność ze zjedzenia ciastka trwa tylko chwilę, ale dobre samopoczucie i zadowolenie z siebie mogą towarzyszyć Ci każdego dnia"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Удовольствие от съеденной булочки длится 5 минут, а своим прекрасным отражением в зеркале можно наслаждаться постоянно"
          }
        }
      }
    },
    "Motivation18" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Instead of sitting and scrolling through social media, admiring how amazing others look, get up and do something to make yourself look amazing"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zamiast siedzieć i przeglądać media społecznościowe, podziwiając, jak świetnie wyglądają inni, wstań i zrób coś, co pomoże Ci poczuć się świetnie we własnej skórze"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вместо того чтобы сидеть и смотреть в социальных сетях, как шикарно выглядят другие, лучше встать и сделать что-то, чтобы самой выглядеть шикарно"
          }
        }
      }
    },
    "Motivation19" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A setback is not the end, just a temporary pause on the way to your goal. Just keep going"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niepowodzenie to nie koniec, a jedynie tymczasowa przerwa na drodze do celu. Po prostu idź dalej"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Срыв — это не конец, а лишь временная задержка на пути к цели. Просто продолжай"
          }
        }
      }
    },
    "Motivation20" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Don't do what's easy, do what will lead you to a beautiful body"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nie rób tego, co łatwe - rób to, co doprowadzi Cię do pięknej sylwetki"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Не делай то, что проще, а делай то, что приведет тебя к красивому телу"
          }
        }
      }
    },
    "Motivation21" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your journey to a healthy weight is a marathon, not a sprint. Persistence and consistency will lead you to success"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Twoja droga do zdrowej wagi to maraton, a nie sprint. Wytrwałość i konsekwencja doprowadzą Cię do sukcesu"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Твой путь к здоровому весу — это марафон, а не спринт. Упорство и постоянство приведут тебя к успеху"
          }
        }
      }
    },
    "Motivation22" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you're looking at your phone and eating right now, put the phone down, enjoy your food, and then get back to other tasks"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jeśli teraz patrzysz w telefon i jesz, odłóż go, ciesz się posiłkiem, a potem wróć do innych zajęć"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если ты сейчас смотришь в телефон и что-то жуешь, отложи его, насладись едой, а потом возвращайся к остальным делам"
          }
        }
      }
    },
    "Motivation23" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Don’t regret not starting to lose weight earlier. Just start doing it now, so there will be no regrets in the future"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nie żałuj, że nie zacząłeś wcześniej odchudzać się. Po prostu zacznij teraz, aby w przyszłości nie mieć żadnych wyrzutów sumienia"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Не жалей, что не начала худеть раньше. Просто начни делать это сейчас, чтобы в будущем не было поводов для сожалений"
          }
        }
      }
    },
    "Motivation24" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Set yourself up for a smooth and lasting process, don’t chase quick results"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zadbaj o spokojny i trwały proces, nie goń za szybkim efektem"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Настраивайся на плавный и продолжительный процесс, не гонись за быстрыми результатами"
          }
        }
      }
    },
    "Motivation25" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Don’t listen to those who say you can’t do it. Believe in yourself and prove to everyone that you’re capable of more"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nie słuchaj tych, którzy mówią, że nie dasz rady. Uwierz w siebie i pokaż wszystkim, że stać Cię na więcej"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Не слушай тех, кто говорит, что у тебя не получится. Верь в себя и докажи всем, что ты способна на большее"
          }
        }
      }
    },
    "Motivation26" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Every step, even the smallest one, brings you closer to your goal. Even if progress seems slow, it’s still there"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Każdy krok, nawet najmniejszy, przybliża Cię do celu. Nawet jeśli postępy wydają się powolne, wciąż są widoczne"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Каждый шаг, даже самый маленький, приближает тебя к цели. Даже если прогресс кажется медленным, он всё равно есть"
          }
        }
      }
    },
    "Motivation27" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Load your menu with vitamins and minerals. The more varied your diet, the better you'll feel"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wzbogacaj swój jadłospis w witaminy i minerały. Im bardziej zróżnicowana dieta, tym lepiej się poczujesz"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Наполни своё меню витаминами и минералами. Чем разнообразнее твоё питание, тем лучше твоё самочувствие"
