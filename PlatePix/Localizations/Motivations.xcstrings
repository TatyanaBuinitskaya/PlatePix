    "Motivation39" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If a walk outdoors isn’t part of your plans today, try to combine it with a trip to the store or your way home"
