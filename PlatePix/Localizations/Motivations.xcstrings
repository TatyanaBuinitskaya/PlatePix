    },
    "Motivation34" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loving yourself means nourishing your body with delicious and healthy food, not sugar and fast food that only harm it"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kochać siebie to odżywiać swoje ciało pysznym i zdrowym jedzeniem, a nie cukrem i fast foodem, które tylko mu szkodzą"
