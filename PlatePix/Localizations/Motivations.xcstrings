    "Motivation50" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Physical activity isn’t just gym workouts, but also walking to work or taking the stairs instead of the elevator"
