    },
    "Motivation33" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Even if you lose only a small part of your excess weight, it’s still a positive step toward your goal"
