        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Любить себя — значит питаться вкусной и полезной едой, а не сахаром и фастфудом, которые разрушают организм"
          }
        }
      }
    },
    "Motivation35" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What matters is not whether you slip up, but how quickly you get back on track with healthy eating"
