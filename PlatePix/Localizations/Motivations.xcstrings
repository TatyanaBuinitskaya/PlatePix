    },
    "Motivation31" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Every time you say no to sweets, it's a victory over yourself and one step closer to your goal"
