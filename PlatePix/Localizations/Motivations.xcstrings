    "Motivation47" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Don’t pay attention to people who drink alcohol and eat a lot of junk food. Just do what will lead you to your goal, not theirs"
