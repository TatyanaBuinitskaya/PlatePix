    "Motivation48" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vegetables and fruits are your best friends: they are rich in vitamins and minerals, and are also low in calories"
